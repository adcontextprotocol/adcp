{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/schemas/3.1.0-rc.6/core/catalog-item-delivery-metrics.json",
  "title": "Catalog Item Delivery Metrics",
  "description": "Delivery metrics row for one catalog item within a package.",
  "allOf": [
    {
      "$ref": "/schemas/3.1.0-rc.6/core/delivery-metrics.json"
    },
    {
      "type": "object",
      "properties": {
        "content_id": {
          "type": "string",
          "description": "Catalog item identifier (e.g., SKU, GTIN, job_id, offering_id)"
        },
        "content_id_type": {
          "$ref": "/schemas/3.1.0-rc.6/enums/content-id-type.json",
          "description": "Identifier type for this content_id"
        }
      },
      "required": [
        "content_id",
        "impressions",
        "spend"
      ]
    }
  ]
}
