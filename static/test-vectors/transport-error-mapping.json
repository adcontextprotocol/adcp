        "suggestion": "Increase budget to at least 500 USD"
      },
      "expected_action": "surface_to_caller"
    },
    {
      "id": "mcp-missing-recovery-unknown-code",
      "description": "Missing recovery field with unknown vendor code — should default to terminal",
      "transport": "mcp",
      "path": "structuredContent",
      "response": {
        "content": [{"type": "text", "text": "Custom vendor error."}],
        "isError": true,
        "structuredContent": {
          "adcp_error": {
            "code": "X_VENDOR_UNKNOWN",
