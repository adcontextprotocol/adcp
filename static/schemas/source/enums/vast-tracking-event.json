{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/schemas/enums/vast-tracking-event.json",
  "title": "VAST Tracking Event",
  "description": "Standard VAST 4.2 tracking events for video ad playback and interaction. Event names align directly to the IAB VAST 4.2 specification.",
  "type": "string",
  "enum": [
    "impression",
    "start",
    "firstQuartile",
    "midpoint",
    "thirdQuartile",
    "complete",
    "mute",
    "unmute",
    "pause",
    "resume",
    "rewind",
    "skip",
    "playerExpand",
    "playerCollapse",
    "fullscreen",
    "exitFullscreen",
    "progress",
    "clickTracking",
    "click",
    "customClick",
    "close",
    "closeLinear",
    "error",
    "notViewable",
    "viewable",
    "measurableImpression",
    "viewableImpression"
  ]
}
