{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/schemas/governance/validate-plan-action-response.json",
  "title": "Validate Plan Action Response",
  "description": "Validation result for an orchestrator action against a campaign plan.",
  "type": "object",
  "properties": {
    "action_id": {
      "type": "string",
      "description": "Unique identifier for this validation record. Use in report_plan_outcome to link outcomes."
    },
    "verdict": {
      "$ref": "/schemas/enums/validation-verdict.json",
      "description": "Validation verdict."
    },
    "categories": {
      "type": "array",
      "description": "Per-category evaluation results.",
      "items": { "$ref": "#/$defs/category_result" }
    },
    "modifications": {
      "type": "array",
      "description": "Suggested modifications. Present only when verdict is 'modification_required'.",
      "items": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "description": "JSON path to the field that should be modified."
          },
          "current_value": {
            "description": "Current value of the field (may be null)."
          },
          "suggested_value": {
            "description": "Suggested replacement value."
          },
          "reason": {
            "type": "string",
            "description": "Why this modification is needed."
          }
        },
        "required": ["field", "suggested_value", "reason"],
        "additionalProperties": false
      }
    },
    "escalation": {
      "type": "object",
      "description": "Escalation details. Present only when verdict is 'escalated'.",
      "properties": {
        "reason": {
          "type": "string",
          "description": "Human-readable explanation of why the action was escalated."
        },
        "severity": {
          "$ref": "/schemas/enums/escalation-severity.json",
          "description": "Escalation severity level."
        },
        "requires_human": {
          "type": "boolean",
          "description": "Whether human approval is required before the agent may proceed."
        }
      },
      "required": ["reason", "severity", "requires_human"],
      "additionalProperties": false
    }
  },
  "required": ["action_id", "verdict", "categories"],
  "additionalProperties": false,
  "$defs": {
    "category_result": {
      "type": "object",
      "properties": {
        "category_id": {
          "type": "string",
          "description": "Validation category identifier."
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "warning"],
          "description": "Category evaluation result."
        },
        "explanation": {
          "type": "string",
          "description": "Human-readable explanation."
        },
        "details": {
          "type": "object",
          "description": "Optional structured details for programmatic consumption.",
          "additionalProperties": true
        }
      },
      "required": ["category_id", "status", "explanation"],
      "additionalProperties": false
    }
  }
}
