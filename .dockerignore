# Dependencies
node_modules
npm-debug.log*

# Build outputs (rebuilt inside Docker)
build
dist
!dist/schemas
dist/schemas/latest
dist/schemas/v*
dist/schemas/registry.*
# Include committed versioned compliance bundles from git — the builder only
# regenerates dist/compliance/latest/, but the Express server serves
# /compliance/{version}/ from the committed tree. Without this un-exclude,
# versioned URLs (/compliance/3.0.3/, /compliance/3.0.4/, etc.) 404 even
# though the files are in the repo.
!dist/compliance
dist/compliance/latest
# Include cosign-signed versioned tarballs from git — the builder only
# regenerates latest.tgz, and re-signing requires OIDC creds we don't
# have inside the Fly.io image build.
!dist/protocol
.docusaurus

# Development files
.git
.github
*.md
!README.md
!CHANGELOG.md
# Shared agent infrastructure — required at runtime by Addie's rules
# loader (server/src/addie/rules/index.ts) and by the triage routines.
!.agents/**
!.claude/agents/**
.venv
.conductor
.context
.changeset
.gemini-clipboard

# Not needed in server build
images
logo
apps

# IDE files
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp

# Logs
logs
*.log

# Coverage
coverage

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Fly.io
fly.toml