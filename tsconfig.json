{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "types": ["jest", "node"],
    "paths": {
      "@adcp/client/testing": ["./node_modules/@adcp/client/dist/lib/testing/index.d.ts"],
      "@adcp/client/auth": ["./node_modules/@adcp/client/dist/lib/auth/index.d.ts"]
    }
  },
  "include": ["tests/**/*", "server/src/**/*"],
  "exclude": ["node_modules", "dist", "docs"]
}
