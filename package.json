    "test:storyboard-provides-state-for": "node --test --test-force-exit --test-timeout=30000 tests/lint-storyboard-provides-state-for.test.cjs",
    "test:storyboard-contradictions": "node --test --test-force-exit --test-timeout=30000 tests/lint-storyboard-contradictions.test.cjs",
